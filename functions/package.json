{
  "name": "functions",
  "version": "1.0.0",
  "scripts": {
    "lint": "eslint --ext .js,.ts .",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "mocha --recursive --require ts-node/register --timeout 10000 'test/**/*.test.ts'",
    "test:watch": "mocha --recursive --require ts-node/register --watch --watch-files src,test 'test/**/*.test.ts'",
    "test:coverage": "nyc mocha --recursive --require ts-node/register --timeout 10000 'test/**/*.test.ts'",
    "test:single": "mocha --require ts-node/register --timeout 10000"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/functions/src/index.js",
  "dependencies": {
    "firebase-admin": "^12.6.0",
    "firebase-functions": "^6.0.1"
  },
  "devDependencies": {
    "@types/chai": "^5.2.2",
    "@types/mocha": "^10.0.10",
    "@types/sinon": "^17.0.4",
    "@typescript-eslint/eslint-plugin": "^5.12.0",
    "@typescript-eslint/parser": "^5.12.0",
    "chai": "^6.0.1",
    "eslint": "^8.9.0",
    "eslint-config-google": "^0.14.0",
    "eslint-plugin-import": "^2.25.4",
    "firebase-functions-test": "^3.4.1",
    "mocha": "^11.7.2",
    "nyc": "^17.1.0",
    "sinon": "^21.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^4.9.0"
  },
  "private": true
}
