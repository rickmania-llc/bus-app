{
  "extension": [".ts"],
  "include": ["src/**/*.ts"],
  "exclude": [
    "**/*.d.ts",
    "**/*.test.ts",
    "**/*.spec.ts",
    "test/**",
    "lib/**",
    "node_modules/**"
  ],
  "reporter": ["text", "lcov", "html", "text-summary"],
  "all": true,
  "check-coverage": true,
  "branches": 80,
  "lines": 80,
  "functions": 80,
  "statements": 80,
  "watermarks": {
    "lines": [80, 95],
    "functions": [80, 95],
    "branches": [80, 95],
    "statements": [80, 95]
  },
  "require": ["ts-node/register"],
  "sourceMap": true
}